pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/dotnet/sdk:10.0' 
            args '-v /var/run/docker.sock:/var/run/docker.sock  -u root'
        }
    }
	
	environment{
		DOTNET_ENVIRONMENT = 'Development'
		IMAGE_NAME = "matejanikolikj/nba-fantasy-app"
		IMAGE_TAG = "latest"
		// Immutable, traceable tag: every build is addressable by its commit SHA so a
		// specific build can be redeployed or rolled back. "latest" is a moving pointer only.
		IMAGE_TAG_SHA = "${env.GIT_COMMIT}"
		DOCKER_HUB_CREDENTIALS = 'docker-hub-credentials'
		GITHUB_CONTEXT = "Jenkins CI Build"
		GITHUB_CRED_ID = 'cb1a22d0-0e56-4363-95f5-5376109acb94'
		GIT_REPO = 'NBAFantasy'
        GIT_ACCOUNT = 'mateja503'
	}

    stages {
		
		stage('Build Application'){
            steps{
				githubNotify(
					account: env.GIT_ACCOUNT,
					repo: env.GIT_REPO,
					credentialsId: env.GITHUB_CRED_ID, // Use the ID from your logs
					sha: env.GIT_COMMIT,
					status: 'PENDING',
					context: env.GITHUB_CONTEXT,
					description: "Building Pipeline...."
				)	
				sh 'dotnet restore NBAFantasy.slnx'
				sh 'dotnet build NBAFantasy.slnx -c Release --no-restore'
            }
        }

		stage('Test') {
			steps {
				// Real test run. --no-build reuses the Release output from the build stage.
				// The pipeline now actually fails when a test fails, instead of echoing success.
				sh 'dotnet test NBAFantasy.slnx -c Release --no-build --logger "trx;LogFileName=test-results.trx"'
			}
			post {
				always {
					// Surface results in Jenkins even on failure (requires the MSTest/xUnit plugin).
					xunit testTimeMargin: '3000', tools: [MSTest(pattern: '**/test-results.trx')]
				}
			}
		}

		stage('Aspire Manifest For Production') {
            steps {
				sh 'dotnet run --project NBAFantasy/NBAFantasy.csproj --publisher manifest --output-path manifest.json'
            }
        }

        stage('Build Image') {
            steps {
					sh """	
							command -v docker >/dev/null 2>&1 || (apt-get update && apt-get install -y docker.io)
							
							dotnet publish NBA.Api/NBA.Api.csproj \
							-p:PublishProfile=DefaultContainer \
							-p:ContainerRepository=${env.IMAGE_NAME} \
							-p:ContainerImageTag=${env.IMAGE_TAG} \
							-p:ContainerRuntimeIdentifier=linux-x64 \
							-c Release

							# Also tag the freshly built image with the commit SHA.
							docker tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} ${env.IMAGE_NAME}:${env.IMAGE_TAG_SHA}
						"""
				}
        }

		stage('Push Image'){
			steps {
					script { // This wrapper is mandatory
						docker.withRegistry('https://registry.hub.docker.com',"${env.DOCKER_HUB_CREDENTIALS}"){
							def image = docker.image("${env.IMAGE_NAME}")
							// Push the immutable SHA tag first, then move "latest".
							image.push("${env.IMAGE_TAG_SHA}")
							image.push("${env.IMAGE_TAG}")
						}
					}
				}
		}
    }
	
	post{
		always{
			sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
			sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG_SHA} || true"

			sh "docker image prune -f"
		}
        success {
			githubNotify(
					account: env.GIT_ACCOUNT,
					repo: env.GIT_REPO,
					credentialsId: env.GITHUB_CRED_ID, // Use the ID from your logs
					sha: env.GIT_COMMIT,
					status: 'SUCCESS',
					context: env.GITHUB_CONTEXT,
					description: "Success"
				)			
        }
        failure {
			githubNotify(
					account: env.GIT_ACCOUNT,
					repo: env.GIT_REPO,
					credentialsId: env.GITHUB_CRED_ID, // Use the ID from your logs
					sha: env.GIT_COMMIT,
					status: 'FAILURE',
					context: env.GITHUB_CONTEXT,
					description: "Failed"
				)	
        }
	}
}
